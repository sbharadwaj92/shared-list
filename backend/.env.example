# Copy to backend/.env and adjust. Real .env is gitignored.
# Bun reads .env automatically — no dotenv import needed.

# Runtime mode. Pino uses pretty transport in development, JSON otherwise.
NODE_ENV=development

# Hono listens on this port; Caddy proxies 443 → here.
PORT=3000

# Postgres connection string. Matches docker-compose defaults.
DATABASE_URL=postgres://shared_list:shared_list@localhost:5432/shared_list

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# HS256 secret for signing access-token JWTs. Must be at least 32 chars.
# Generate one with: openssl rand -base64 48
# In dev, any 32+ char string is fine. NEVER reuse this across environments.
JWT_SECRET=dev-only-secret-change-me-please-32chars-min

# Access token lifetime in seconds (default 900 = 15 min).
ACCESS_TOKEN_TTL_SEC=900

# Refresh token lifetime in seconds (default 2592000 = 30 days).
REFRESH_TOKEN_TTL_SEC=2592000
