# Copy to backend/.env and adjust. Real .env is gitignored.
# Bun reads .env automatically — no dotenv import needed.

# Runtime mode. Pino uses pretty transport in development, JSON otherwise.
NODE_ENV=development

# Hono listens on this port; Caddy proxies 443 → here.
PORT=3000

# Postgres connection string. Matches docker-compose defaults.
DATABASE_URL=postgres://shared_list:shared_list@localhost:5432/shared_list

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# HS256 secret for signing access-token JWTs. Must be at least 32 chars.
# Generate one with: openssl rand -base64 48
# In dev, any 32+ char string is fine. NEVER reuse this across environments.
JWT_SECRET=dev-only-secret-change-me-please-32chars-min

# Access token lifetime in seconds (default 900 = 15 min).
ACCESS_TOKEN_TTL_SEC=900

# Refresh token lifetime in seconds (default 2592000 = 30 days).
REFRESH_TOKEN_TTL_SEC=2592000

# --- Push delivery (Phase 10+) ---
# Push is opt-in. With PUSH_ENABLED=false (default) the server boots
# normally and the push subsystem is a no-op — no APNs/FCM creds needed.
# Set to true and provide credentials below to enable real delivery.
PUSH_ENABLED=false

# APNs (Apple Push Notification service).
# Get APNS_TEAM_ID and APNS_KEY_ID from developer.apple.com; download the
# .p8 and paste its contents into APNS_PRIVATE_KEY (escape newlines as \n).
# APNS_BUNDLE_ID is the iOS app bundle id; APNs rejects topics that don't
# match the cert. Use sandbox endpoint for dev builds.
# APNS_TEAM_ID=
# APNS_KEY_ID=
# APNS_PRIVATE_KEY=
# APNS_BUNDLE_ID=
# APNS_USE_SANDBOX=true

# FCM (Firebase Cloud Messaging) HTTP v1.
# Get FCM_PROJECT_ID and the service account JSON from console.firebase.google.com.
# Paste the entire JSON (single-line, escape inner quotes) as FCM_SERVICE_ACCOUNT_JSON.
# FCM_PROJECT_ID=
# FCM_SERVICE_ACCOUNT_JSON=
