    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "pino": "^9.5.0",
    "postgres": "^3.4.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.0.0",
    "testcontainers": "^11.14.0",
    "typescript": "^5.7.2"
  }
}
