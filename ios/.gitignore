# XcodeGen generates SharedList.xcodeproj from project.yml. Treat it as a build
# artifact: the source of truth is project.yml. Anyone who clones the repo runs
# `cd ios && xcodegen generate` (or `make ios` from the repo root once that
# wrapper exists). This avoids the merge-conflict tax of a checked-in pbxproj.
SharedList.xcodeproj/

# Info.plist is also generated by XcodeGen from `info.properties` in
# project.yml. Authoring `info.properties` is the single source of truth;
# the file on disk is regenerated on every `xcodegen generate` invocation.
SharedList/Resources/Info.plist

# Standard Xcode build/derived-data junk.
build/
DerivedData/
*.xcuserstate
xcuserdata/

# Swift Package Manager workspace state inside Xcode (regenerated on demand).
*.xcworkspace/xcuserdata/
.swiftpm/

# macOS Finder turds.
.DS_Store
